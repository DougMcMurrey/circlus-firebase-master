{
	"name": "functions",
	"description": "Cloud Functions for Firebase",
	"scripts": {
		"lint": "eslint .",
		"format": "prettier --write \"src/**/*.{js,less,json}\"",
		"deploy": "firebase deploy --only functions",
		"deploy:dev": "bash ./scripts/deploy-dev-functions.sh",
		"serve": "firebase serve --only functions",
		"logs": "firebase functions:log",
		"jest": "jest --colors --verbose",
		"jest:watch": "jest --colors --verbose --watch",
		"test-email-send": "NODE_ENV=development node testing/testEmails.js",
		"test:email": "jest src/email/templates.spec.js",
		"cli": "node cli.js",
		"csv": "node ./scripts/generate_csv.js",
		"setup": "node setup.js && firebase functions:config:get",
		"setup:unset-products": "firebase functions:config:unset stripe.club_plan_id,stripe.club_product_id"
	},
	"engines": {
		"node": "10"
	},
	"dependencies": {
		"@sendgrid/mail": "^6.5.5",
		"argon2": "^0.25.0",
		"base64-img": "^1.0.4",
		"body-parser": "^1.19.0",
		"child-process-promise": "^2.2.1",
		"cookie-parser": "^1.4.5",
		"cors": "^2.8.5",
		"crypto-random-string": "^3.2.0",
		"email-templates": "^6.1.1",
		"express": "^4.17.1",
		"express-bearer-token": "^2.4.0",
		"firebase-admin": "^8.10.0",
		"firebase-functions": "^3.5.0",
		"firebase-tools": "^7.16.0",
		"jimp": "^0.9.6",
		"jsonwebtoken": "^8.5.1",
		"ms": "^2.1.2",
		"nodemailer": "^6.4.6",
		"pug": "^2.0.4",
		"sha.js": "^2.4.11",
		"stripe": "^7.15.0",
		"vcfer": "^1.1.1"
	},
	"devDependencies": {
		"@types/node-fetch": "^2.5.5",
		"@types/stripe": "^7.13.22",
		"@types/vorpal": "^1.12.0",
		"chalk": "^3.0.0",
		"dotenv-flow": "^3.1.0",
		"eslint": "^5.12.0",
		"faker": "^4.1.0",
		"firebase-functions-test": "^0.1.7",
		"jest": "^24.9.0",
		"minimist": "^1.2.5",
		"moment": "^2.24.0",
		"node-fetch": "^2.6.0",
		"papaparse": "^5.1.1",
		"prettier": "^1.19.1",
		"table": "^5.4.6",
		"vorpal": "^1.12.0",
		"acorn": "^7.1.1"
	},
	"private": true
}
